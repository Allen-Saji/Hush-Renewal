# HushRenewal negotiation-agent configuration.
# Copy to .env and fill in, or export these before running.
# Run TWO processes from this same package -- one per role.

# --- Identity (the only setting that differs between the two agents) ---
AGENT_ROLE=customer          # customer | vendor
PORT=8100                    # customer 8100, vendor 8200 (any two free ports)

# --- Groq (reasoning runtime; NOT part of the product's tech stack) ---
# One shared key works. For total isolation, give each agent its own:
#   CUSTOMER_GROQ_API_KEY / VENDOR_GROQ_API_KEY  (role-specific wins).
GROQ_API_KEY=gsk_changeme
# CUSTOMER_GROQ_API_KEY=gsk_...
# VENDOR_GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=                # only if pointing at an OpenAI-compatible proxy
REASONING_TEMPERATURE=0.4
DECISION_TEMPERATURE=0.0
MAX_REASONING_TOKENS=800

# --- Matcher backend (where the sealed number is submitted) ---
BACKEND_URL=http://localhost:8000

# --- Application ---
APP_ENV=dev
LOG_LEVEL=INFO
LOG_JSON=false
HTTP_TIMEOUT_SECONDS=60
# CORS: tighten to the deployed frontend origin in production.
CORS_ORIGINS=*
