module Test where

import Main
import Daml.Script
import DA.Date (date, Month(..))
import DA.Time (time)
import DA.Optional (isNone)

allocateP : Text -> Script Party
allocateP hint = allocatePartyByHint (PartyIdHint hint)

test_deal : Script ()
test_deal = script do

  matcher  <- allocateP "Matcher"
  customer <- allocateP "Customer"
  vendor   <- allocateP "Vendor"

  roundCid <- submit matcher do
    createCmd RenewalRound with
      matcher; customer; vendor
      roundId      = "ROUND-001"
      subscription = "Salesforce Enterprise"
      deadline     = time (date 2026 Jul 2) 0 0 0

  bidCid <- submit customer do
    createCmd SealedBid with
      customer; matcher
      roundId  = "ROUND-001"
      maxPrice = 100000.0

  askCid <- submit vendor do
    createCmd SealedAsk with
      vendor; matcher
      roundId  = "ROUND-001"
      minPrice = 80000.0

  resultCid <- submit matcher do
    exerciseCmd roundCid Clear with
      bidCid; askCid
      dealPrice = 90000.0

  result <- queryContractId matcher resultCid
  case result of
    None -> abort "Result contract not found"
    Some r -> do
      assertMsg "Expected DEAL" (r.outcome == "DEAL")
      assertMsg "Expected price of 90000" (r.price == Some 90000.0)

  pure ()

test_no_deal : Script ()
test_no_deal = script do

  matcher  <- allocateP "Matcher"
  customer <- allocateP "Customer"
  vendor   <- allocateP "Vendor"

  roundCid <- submit matcher do
    createCmd RenewalRound with
      matcher; customer; vendor
      roundId      = "ROUND-002"
      subscription = "Workday Enterprise"
      deadline     = time (date 2026 Jul 2) 0 0 0

  bidCid <- submit customer do
    createCmd SealedBid with
      customer; matcher
      roundId  = "ROUND-002"
      maxPrice = 70000.0

  askCid <- submit vendor do
    createCmd SealedAsk with
      vendor; matcher
      roundId  = "ROUND-002"
      minPrice = 90000.0

  resultCid <- submit matcher do
    exerciseCmd roundCid Clear with
      bidCid; askCid
      dealPrice = 0.0

  result <- queryContractId matcher resultCid
  case result of
    None -> abort "Result contract not found"
    Some r -> do
      assertMsg "Expected NO_DEAL" (r.outcome == "NO_DEAL")
      assertMsg "Expected no price revealed" (r.price == None)

  pure ()

test_settlement : Script ()
test_settlement = script do

  matcher  <- allocateP "Matcher"
  customer <- allocateP "Customer"
  vendor   <- allocateP "Vendor"

  roundCid <- submit matcher do
    createCmd RenewalRound with
      matcher; customer; vendor
      roundId      = "ROUND-003"
      subscription = "Workday Enterprise"
      deadline     = time (date 2026 Jul 2) 0 0 0

  bidCid <- submit customer do
    createCmd SealedBid with
      customer; matcher
      roundId  = "ROUND-003"
      maxPrice = 100000.0

  askCid <- submit vendor do
    createCmd SealedAsk with
      vendor; matcher
      roundId  = "ROUND-003"
      minPrice = 80000.0

  resultCid <- submit matcher do
    exerciseCmd roundCid Clear with
      bidCid; askCid
      dealPrice = 90000.0

  cashCid <- submit customer do
    createCmd Cash with
      owner   = customer
      issuer  = customer
      amount  = 90000.0
      matcher = matcher

  (licenceCid, vendorCashCid) <- submitWithOptions
    (actAs [matcher, customer, vendor])
    do exerciseCmd resultCid Settle with
         cashCid

  licence <- queryContractId customer licenceCid
  case licence of
    None -> abort "Licence not found"
    Some l -> do
      assertMsg "Licence owner should be customer" (l.customer == customer)
      assertMsg "Licence subscription correct" (l.subscription == "Workday Enterprise")
      assertMsg "Licence price should be 90000" (l.price == 90000.0)

  vendorCash <- queryContractId vendor vendorCashCid
  case vendorCash of
    None -> abort "Vendor cash not found"
    Some c -> do
      assertMsg "Cash owner should be vendor" (c.owner == vendor)
      assertMsg "Cash amount should be 90000" (c.amount == 90000.0)

  pure ()

test_privacy : Script ()
test_privacy = script do

  matcher  <- allocateP "Matcher"
  customer <- allocateP "Customer"
  vendor   <- allocateP "Vendor"

  _ <- submit matcher do
    createCmd RenewalRound with
      matcher; customer; vendor
      roundId      = "ROUND-P"
      subscription = "Test"
      deadline     = time (date 2026 Jul 2) 0 0 0

  bidCid <- submit customer do
    createCmd SealedBid with
      customer; matcher
      roundId  = "ROUND-P"
      maxPrice = 100.0

  askCid <- submit vendor do
    createCmd SealedAsk with
      vendor; matcher
      roundId  = "ROUND-P"
      minPrice = 80.0

  vendorSeesBid <- queryContractId vendor bidCid
  assertMsg "Vendor must not see the customer's sealed bid" (isNone vendorSeesBid)

  customerSeesAsk <- queryContractId customer askCid
  assertMsg "Customer must not see the vendor's sealed ask" (isNone customerSeesAsk)

  pure ()
