# HushRenewal backend configuration.
# Ledger credentials mirror the names in ~/.config/seaport-devnet.env, so you can:
#   set -a; source ~/.config/seaport-devnet.env; set +a
# or copy this file to .env and fill it in. NEVER commit real secrets.

# --- Seaport 5n-sandbox DevNet (JSON Ledger API v2 + OIDC m2m) ---
CANTON_DEVNET_JSON_API_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
CANTON_DEVNET_WS_URL=wss://ledger-api.validator.devnet.sandbox.fivenorth.io
CANTON_DEVNET_OIDC_TOKEN_URL=https://auth.sandbox.fivenorth.io/application/o/token/
CANTON_DEVNET_OIDC_CLIENT_ID=validator-devnet-m2m
CANTON_DEVNET_OIDC_CLIENT_SECRET=changeme
CANTON_DEVNET_OIDC_AUDIENCE=validator-devnet-m2m
CANTON_DEVNET_OIDC_SCOPE=daml_ledger_api

# --- Application ---
APP_ENV=dev
LOG_LEVEL=INFO
LOG_JSON=false
DEMO_MODE=true
HTTP_TIMEOUT_SECONDS=60
TOKEN_REFRESH_LEEWAY_SECONDS=300

# --- Canton parties (not secret; allocated on the 5n sandbox) ---
LEDGER_NAMESPACE=1220a14ca128063b8dc9d1ebb0bd22633be9f2168500f4dbc1ecaeb1855b14e5acf8
MATCHER_PARTY_HINT=hushrenewal-matcher-1
CUSTOMER_PARTY_HINT=hushrenewal-customer-1
VENDOR_PARTY_HINT=hushrenewal-vendor-1
